# HTML nie cachen – damit Updates sofort wirksam werden
<FilesMatch "\.(html)$">
  Header always set Cache-Control "no-cache, no-store, must-revalidate"
  Header always set Pragma "no-cache"
  Header always set Expires "0"
</FilesMatch>

# JS/CSS/Assets lange cachen (Vite baut mit Hash-Dateinamen)
<FilesMatch "\.(js|css|woff2?|ttf|svg|png|jpg|ico)$">
  Header always set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Clickjacking verhindern
Header always set X-Frame-Options "DENY"

# MIME-Sniffing verhindern
Header always set X-Content-Type-Options "nosniff"

# Referrer-Informationen einschränken
Header always set Referrer-Policy "no-referrer"

# Nur HTTPS erlauben (1 Jahr)
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

# Content Security Policy
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'"
